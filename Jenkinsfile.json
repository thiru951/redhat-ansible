pipeline {
    agent any

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/thiru951/redhat-ansible.git'
            }
        }

        stage('Run Ansible Playbook') {
            steps {
                sh """
                ansible-playbook -i inventory.yml patch.yml
                """
            }
        }
    }
}
